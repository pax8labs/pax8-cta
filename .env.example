# AgentSync Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# ⚠️  SECURITY WARNING - Demo Mode
# ===========================================
# Demo mode bypasses ALL authentication and security checks
# ⚠️  NEVER use DEMO_MODE=true in production environments!
# ⚠️  Only use for local development and testing
#
# For production, set DEMO_MODE=false and configure Azure AD credentials below
DEMO_MODE=false

# ===========================================
# Partner / MSP Configuration
# ===========================================
# Azure AD App Registration for GDAP authentication
PARTNER_CLIENT_SECRET=your-client-secret-here

# ===========================================
# Web Dashboard Configuration
# ===========================================
# NextAuth.js configuration
# IMPORTANT: Update this to match your actual dev server port (usually 3000)
NEXTAUTH_URL=http://localhost:3000

# ⚠️  REQUIRED: Session secret (minimum 32 characters)
# Generate a secure secret with: openssl rand -base64 32
# This is REQUIRED for production - the app will refuse to start without it
NEXTAUTH_SECRET=

# ===========================================
# ⚠️  REQUIRED: Azure AD Authentication
# ===========================================
# These credentials are REQUIRED for production deployment
# The app will refuse to start without valid Azure AD configuration
#
# Setup instructions:
# 1. Go to https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# 2. Create a new App Registration (or use existing)
# 3. Set "Accounts in any organizational directory (Multitenant)"
# 4. Add API permission: Dynamics CRM > user_impersonation
# 5. Create a client secret and copy the values below
#
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ===========================================
# Infrastructure
# ===========================================

# Redis (REQUIRED for deployments)
# Format: redis://[username:password@]host:port[/database]
REDIS_URL=redis://localhost:6379

# ===========================================
# ⚠️  CRITICAL: Database Configuration
# ===========================================
# Path to SQLite database file
# ⚠️  IMPORTANT: Worker and web MUST use the SAME path!
# If paths differ, deployment status updates will be invisible to the web UI
#
# Recommendations:
# - Development: Use relative path like ./data/agentsync.db
# - Production: Use absolute path like /app/data/agentsync.db to avoid ambiguity
# - Ensure directory exists and has write permissions
DATABASE_PATH=./data/agentsync.db

# PostgreSQL (alternative to SQLite - not currently supported)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentsync

# ===========================================
# Azure Key Vault (optional - for production)
# ===========================================
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net

# ===========================================
# Worker Configuration
# ===========================================

# Enable worker processes on this instance
# Set to 'true' for worker nodes, 'false' for web-only nodes
# In development, typically set to 'true' to run workers locally
START_WORKERS=true

# Enable scheduled deployment worker
# Set to 'false' to disable cron-based scheduled deployments
# Requires START_WORKERS=true to take effect
ENABLE_SCHEDULER=true

# Number of concurrent deployment jobs per worker
# ⚠️  IMPORTANT: SQLite concurrency limits (see Issue #172)
# - Recommended: 3 for SQLite (default)
# - Can increase to 10-20 if using PostgreSQL in the future
# - Higher values may cause "database is locked" errors with SQLite
WORKER_CONCURRENCY=3

# Rate limiting (API endpoints)
RATE_LIMIT_MAX=10
RATE_LIMIT_DURATION=60000

# ===========================================
# Storage Directories
# ===========================================

# Directory for solution ZIP files
# Ensure this directory has sufficient disk space for solution packages
SOLUTIONS_DIR=./solutions

# Snapshot storage for rollbacks (future feature)
SNAPSHOT_DIR=./snapshots

# Config file path
CONFIG_PATH=./config/tenants.yaml

# ===========================================
# Analytics & Monitoring (PostHog)
# ===========================================
# Get your API key from https://posthog.com
# NEXT_PUBLIC prefix makes it available in browser
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Enable PostHog debug mode in development (optional)
# NEXT_PUBLIC_POSTHOG_DEBUG=true

# ===========================================
# AI Assistant (Anthropic Claude)
# ===========================================
# API key for AI chat assistant features
# Get your API key from https://console.anthropic.com
# The chat assistant works in demo mode without this key (uses mock responses)
# For production AI features, provide a valid key
ANTHROPIC_API_KEY=

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info
NODE_ENV=development

# ===========================================
# Application
# ===========================================
APP_VERSION=0.1.0

# ===========================================
# Production Deployment Checklist
# ===========================================
# Before deploying to production, verify:
#
# Security:
# ✅ DEMO_MODE=false (or completely removed)
# ✅ NEXTAUTH_SECRET is set and strong (32+ characters)
# ✅ AZURE_AD_* credentials are configured with production values
# ✅ No hardcoded secrets in code or config files
#
# Database & Storage:
# ✅ DATABASE_PATH is set to ABSOLUTE path (e.g., /app/data/agentsync.db)
# ✅ Same DATABASE_PATH used across all web and worker instances
# ✅ Database directory exists with write permissions
# ✅ SOLUTIONS_DIR has sufficient disk space for solution packages
#
# Infrastructure:
# ✅ REDIS_URL points to production Redis instance (not localhost)
# ✅ Redis has sufficient memory and persistence configured
# ✅ WORKER_CONCURRENCY tuned for your database (3 for SQLite, 10-20 for PostgreSQL)
#
# Workers:
# ✅ START_WORKERS=true on at least one instance
# ✅ ENABLE_SCHEDULER=true if using scheduled deployments
# ✅ Multiple worker instances for high availability
#
# Monitoring:
# ✅ PostHog analytics configured (optional but recommended)
# ✅ Log aggregation configured for production debugging
# ✅ Health check endpoint monitored: /api/health/ready
#
# Testing:
# ✅ Test deployment with one tenant before full rollout
# ✅ Verify health check returns 200: curl http://your-app/api/health/ready
# ✅ Confirm Redis connection works
# ✅ Confirm database path is accessible
# ✅ Verify workers are processing jobs
# ===========================================
