# Pax8 CTA CLI environment configuration
# Copy to .env and fill in your values

# Required for real (non-demo) deployments
PARTNER_CLIENT_SECRET=your-client-secret-here

# Optional CLI behavior
DEMO_MODE=false
CONFIG_PATH=./config/tenants.yaml
LOG_LEVEL=info
NODE_ENV=development

# Optional local paths
SOLUTIONS_DIR=./solutions
SNAPSHOT_DIR=./snapshots
