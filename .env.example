# AgentSync Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# ⚠️  SECURITY WARNING - Demo Mode
# ===========================================
# Demo mode bypasses ALL authentication and security checks
# ⚠️  NEVER use DEMO_MODE=true in production environments!
# ⚠️  Only use for local development and testing
#
# For production, set DEMO_MODE=false and configure Azure AD credentials below
DEMO_MODE=false

# ===========================================
# Partner / MSP Configuration
# ===========================================
# Azure AD App Registration for GDAP authentication
PARTNER_CLIENT_SECRET=your-client-secret-here

# ===========================================
# Web Dashboard Configuration
# ===========================================
# NextAuth.js configuration
# IMPORTANT: Update this to match your actual dev server port (usually 3000)
NEXTAUTH_URL=http://localhost:3000

# ⚠️  REQUIRED: Session secret (minimum 32 characters)
# Generate a secure secret with: openssl rand -base64 32
# This is REQUIRED for production - the app will refuse to start without it
NEXTAUTH_SECRET=

# ===========================================
# ⚠️  REQUIRED: Azure AD Authentication
# ===========================================
# These credentials are REQUIRED for production deployment
# The app will refuse to start without valid Azure AD configuration
#
# Setup instructions:
# 1. Go to https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# 2. Create a new App Registration (or use existing)
# 3. Set "Accounts in any organizational directory (Multitenant)"
# 4. Add API permission: Dynamics CRM > user_impersonation
# 5. Create a client secret and copy the values below
#
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ===========================================
# Infrastructure
# ===========================================
# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# PostgreSQL (optional - for persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/csd

# ===========================================
# Azure Key Vault (optional - for production)
# ===========================================
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net

# ===========================================
# Worker Configuration
# ===========================================
# Concurrent deployments per worker
WORKER_CONCURRENCY=5

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_DURATION=60000

# Snapshot storage for rollbacks
SNAPSHOT_DIR=./snapshots

# Config file path
CONFIG_PATH=./config/tenants.yaml

# ===========================================
# Analytics & Monitoring (PostHog)
# ===========================================
# Get your API key from https://posthog.com
# NEXT_PUBLIC prefix makes it available in browser
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Enable PostHog debug mode in development (optional)
# NEXT_PUBLIC_POSTHOG_DEBUG=true

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info
NODE_ENV=development

# ===========================================
# Application
# ===========================================
APP_VERSION=0.1.0
