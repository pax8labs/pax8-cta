# AgentSync Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Demo Mode (for testing without Azure setup)
# ===========================================
# Set to true to enable demo mode with mock data
DEMO_MODE=true

# ===========================================
# Partner / MSP Configuration
# ===========================================
# Azure AD App Registration for GDAP authentication
PARTNER_CLIENT_SECRET=your-client-secret-here

# ===========================================
# Web Dashboard Configuration
# ===========================================
# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate-a-random-secret-here

# Azure AD authentication for web dashboard
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# ===========================================
# Infrastructure
# ===========================================
# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# PostgreSQL (optional - for persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/csd

# ===========================================
# Azure Key Vault (optional - for production)
# ===========================================
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net

# ===========================================
# Worker Configuration
# ===========================================
# Concurrent deployments per worker
WORKER_CONCURRENCY=5

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_DURATION=60000

# Snapshot storage for rollbacks
SNAPSHOT_DIR=./snapshots

# Config file path
CONFIG_PATH=./config/tenants.yaml

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info
NODE_ENV=development

# ===========================================
# Application
# ===========================================
APP_VERSION=0.1.0
