# Copilot Studio Deployer - Environment Variables

# Required: Azure AD App Registration Client Secret
# This is the secret for your partner tenant's app registration
PARTNER_CLIENT_SECRET=your-client-secret-here

# Optional: Redis URL (defaults to redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Optional: Worker concurrency (defaults to 5)
WORKER_CONCURRENCY=5

# Optional: Config file path (defaults to ./config/tenants.yaml)
CONFIG_PATH=./config/tenants.yaml
