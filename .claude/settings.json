{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh repo *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch"
    ],
    "deny": ["Bash(git push --force *)", "Bash(git reset --hard *)", "Bash(rm -rf *)", "Read(.env)"]
  }
}
