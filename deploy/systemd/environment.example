# /etc/csd/environment
# Copy this file to /etc/csd/environment and fill in values

# Redis connection
REDIS_URL=redis://localhost:6379

# Config file path
CONFIG_PATH=/opt/copilot-studio-deployer/config/tenants.yaml

# Partner credentials
PARTNER_CLIENT_SECRET=your-client-secret

# Web dashboard auth
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=generate-a-random-secret
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=your-tenant-id

# Worker settings
WORKER_CONCURRENCY=5
SNAPSHOT_DIR=/opt/copilot-studio-deployer/snapshots

# Logging
LOG_LEVEL=info
