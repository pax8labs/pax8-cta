{
  "name": "@pax8/cta",
  "version": "0.1.5",
  "description": "Pax8 Cross-Tenant Agents (CTA) — deploy Copilot Studio agents across a customer fleet via GDAP",
  "license": "Apache-2.0",
  "author": "Pax8, Inc.",
  "homepage": "https://github.com/pax8labs/pax8-cta",
  "repository": {
    "type": "git",
    "url": "https://github.com/pax8labs/pax8-cta.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "pax8-cta": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/binaries",
    "demo-data"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src/",
    "build:binary": "bun build --compile ./src/index.ts --outfile pax8-cta",
    "build:macos-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile dist/binaries/pax8-cta-macos-arm64",
    "build:macos-x64": "bun build --compile --target=bun-darwin-x64 ./src/index.ts --outfile dist/binaries/pax8-cta-macos-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile dist/binaries/pax8-cta-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 ./src/index.ts --outfile dist/binaries/pax8-cta-linux-arm64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 ./src/index.ts --outfile dist/binaries/pax8-cta-windows-x64.exe",
    "build:all": "node -e \"require('fs').mkdirSync('dist/binaries',{recursive:true})\" && npm run build:macos-arm64 && npm run build:macos-x64 && npm run build:linux-x64 && npm run build:linux-arm64 && npm run build:windows-x64",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('pax8-cta',{force:true});\""
  },
  "dependencies": {
    "@pax8/cta-core": "workspace:*",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "12.0.0",
    "conf": "15.1.0",
    "inquirer": "13.3.2",
    "jszip": "3.10.1",
    "open": "11.0.0",
    "ora": "9.3.0",
    "posthog-node": "5.21.0"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "1.3.0"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "devDependencies": {
    "@types/inquirer": "9.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "4.1.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
