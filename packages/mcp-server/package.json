{
  "name": "@agentsync/mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for AgentSync deployment management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentsync-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "agentsync",
    "copilot",
    "deployment",
    "automation",
    "claude",
    "ai"
  ],
  "author": "Pax8 Labs",
  "license": "Apache-2.0",
  "dependencies": {
    "@agentsync/core": "workspace:*",
    "@modelcontextprotocol/sdk": "0.6.0",
    "winston": "3.11.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/node": "20.11.5",
    "@vitest/coverage-v8": "1.6.1",
    "typescript": "5.3.3",
    "vitest": "1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pax8labs/agentsync.git",
    "directory": "packages/mcp-server"
  }
}
