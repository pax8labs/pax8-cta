{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm install && pnpm build",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && pnpm install",
  "functions": {
    "src/app/api/deployments/process/route.ts": {
      "maxDuration": 300
    }
  },
  "env": {
    "REDIS_MODE": "memory"
  }
}
