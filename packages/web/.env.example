# =============================================================================
# AgentSync Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------------------------------------------
# Mode Configuration
# -----------------------------------------------------------------------------

# Set to 'true' to use demo/mock data (no real API calls)
DEMO_MODE=true

# Set to 'true' to enable tenant discovery via GDAP
# Requires PARTNER_* credentials to be set
TENANT_DISCOVERY_ENABLED=false

# -----------------------------------------------------------------------------
# Partner (MSP) Credentials
# -----------------------------------------------------------------------------
# These are your MSP/Partner tenant credentials used for:
# - GDAP tenant discovery
# - Delegated authentication to customer tenants
# - Power Platform Admin API access

# Your partner/MSP Azure AD tenant ID
PARTNER_TENANT_ID=

# App Registration client ID (must have GDAP and Power Platform permissions)
PARTNER_CLIENT_ID=

# App Registration client secret
PARTNER_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Source Environment (Agent Repository)
# -----------------------------------------------------------------------------
# The Dataverse environment where your agent solutions are stored
# This is where deployments pull the solution packages from

# Source tenant ID (can be same as PARTNER_TENANT_ID)
SOURCE_TENANT_ID=

# Source environment URL (e.g., https://yourorg.crm.dynamics.com)
SOURCE_ENVIRONMENT_URL=

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------

# NextAuth secret for session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL for NextAuth callbacks (set to your deployment URL in production)
NEXTAUTH_URL=http://localhost:3000

# Azure AD OAuth (for user login)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# -----------------------------------------------------------------------------
# Redis (Optional - for production job queue)
# -----------------------------------------------------------------------------
# If not set, uses in-memory queue (fine for development)

REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Database (Optional - for persistent storage)
# -----------------------------------------------------------------------------
# If not set, uses file-based storage in demo mode

DATABASE_URL=

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable connection reference mapping UI
CONNECTION_MAPPING_ENABLED=false

# Enable environment variable configuration UI
ENV_VARIABLES_ENABLED=false

# Cache TTL for tenant discovery (in minutes)
GDAP_CACHE_TTL_MINUTES=60

# -----------------------------------------------------------------------------
# Azure AD App Registration Requirements
# -----------------------------------------------------------------------------
# Your App Registration needs the following API permissions:
#
# Microsoft Graph (Application):
#   - DelegatedAdminRelationship.Read.All (for GDAP discovery)
#
# Dynamics CRM / Power Platform (Delegated or Application):
#   - user_impersonation
#
# Power Platform Admin (if using admin API):
#   - Environments.Read.All
#
# Don't forget to grant admin consent for these permissions!
