{
  "name": "@agentsync/core",
  "version": "0.1.0",
  "description": "Core logic for AgentSync - sync and track agent deployments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
