{
  "name": "@pax8/cta-core",
  "version": "0.1.10",
  "license": "Apache-2.0",
  "author": "Pax8, Inc.",
  "homepage": "https://github.com/pax8labs/pax8-cta",
  "repository": {
    "type": "git",
    "url": "https://github.com/pax8labs/pax8-cta.git",
    "directory": "packages/core"
  },
  "description": "Core logic for Pax8 Cross-Tenant Agents (CTA) — cross-tenant Copilot Studio deployments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/msal-node": "5.3.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "fast-check": "^4.8.0",
    "msw": "2.14.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
