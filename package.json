{
  "name": "pax8-cta-monorepo",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Pax8 Cross-Tenant Agents (CTA) — multi-tenant Copilot Studio deployments via GDAP",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @pax8/cta-core build && pnpm -r test",
    "test:coverage": "pnpm --filter @pax8/cta-core build && pnpm -r test -- --coverage",
    "cli": "pnpm --filter @pax8/cta start",
    "db:migrate": "echo 'Run: psql $DATABASE_URL < packages/core/src/db/schema.sql'",
    "clean": "pnpm -r exec node -e \"var fs=require('fs');['dist','.next','node_modules/.cache'].forEach(function(d){fs.rmSync(d,{recursive:true,force:true})})\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "25.9.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "6.4.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "workspaces": [
    "packages/cli",
    "packages/core"
  ],
  "pnpm": {
    "overrides": {
      "uuid": "^11"
    }
  }
}
