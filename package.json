{
  "name": "agentsync",
  "version": "0.1.0",
  "private": true,
  "description": "Sync your Copilot Studio agents to all your tenants",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test -- --coverage",
    "test:e2e": "pnpm --filter @agentsync/web test:e2e",
    "cli": "pnpm --filter @agentsync/cli start",
    "web": "pnpm --filter @agentsync/web dev",
    "worker": "pnpm --filter @agentsync/worker start",
    "docker:build": "docker build -t agentsync:latest .",
    "docker:build:web": "docker build --target web -t agentsync-web:latest .",
    "docker:build:worker": "docker build --target worker -t agentsync-worker:latest .",
    "docker:build:cli": "docker build --target cli -t agentsync-cli:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "echo 'Run: psql $DATABASE_URL < packages/core/src/db/schema.sql'",
    "clean": "pnpm -r exec rm -rf dist .next node_modules/.cache"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
