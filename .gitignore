# Dependencies
node_modules/

# Build outputs
dist/
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example
!.env.sandbox.example

# Config with secrets (keep example)
config/tenants.yaml

# IDE
.vscode/
.idea/

# Claude Code: agent worktrees are harness scratch; settings.local.json
# is per-user local config (permissions, env, etc.) and must never be
# committed. Other .claude/ content (skills, commands, settings.json) is
# intentionally checked in.
.claude/worktrees/
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Solutions (exported files)
solutions/*.zip
agent packages/
# Phase 1 deploy-preflight ships an example precondition manifest with the
# repo. The directory is otherwise gitignored (it's where users drop their
# own .zip solutions), so allow YAML sidecars back in.
!agent packages/
agent packages/*.zip
packages/web/solutions/

# Rollback snapshots
snapshots/

# CLI binaries (local builds)
packages/cli/agentsync
packages/cli/config/

# Next.js
.next/
out/

# Test coverage
coverage/

# Demo mode data
.demo-*.json
.agentsync-settings.json
.agentsync-salt
.agentsync-encryption-key

# SQLite database
data/

# Playwright
playwright-report/
test-results/
config/tenants.sandbox.yaml
test-solutions/

# MSW recorded fixtures (may contain real API responses)
*.recorded.json

# Credentials and secrets
*.pem
*.key
*.p12
*.pfx
