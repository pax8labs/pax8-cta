# AgentSync Sandbox Environment Configuration
# Copy this file to .env.sandbox and fill in your values
# This is for TESTING ONLY - do not use in production

# ===========================================
# Sandbox Mode
# ===========================================
DEMO_MODE=false
ENVIRONMENT=sandbox
SANDBOX_MODE=true

# ===========================================
# Partner / MSP Sandbox Configuration
# ===========================================
# These should point to your sandbox Azure AD tenant
PARTNER_TENANT_ID=your-sandbox-tenant-id-here
PARTNER_CLIENT_ID=your-sandbox-app-registration-id-here
PARTNER_CLIENT_SECRET=your-sandbox-client-secret-here

# ===========================================
# Source Environment (Development)
# ===========================================
# Where your test Copilot agents are developed
SOURCE_TENANT_ID=your-sandbox-tenant-id-here
SOURCE_ENVIRONMENT_URL=https://agentsync-dev-source.crm.dynamics.com

# ===========================================
# Infrastructure
# ===========================================
# Redis (for job queue)
# Local development: redis://localhost:6379
# CI/CD: Use Azure Redis connection string from Key Vault
REDIS_URL=redis://localhost:6379

# Database (SQLite for sandbox)
DATABASE_PATH=./data/agentsync-sandbox.db

# ===========================================
# Configuration
# ===========================================
# Path to sandbox tenant configuration
CONFIG_PATH=./config/tenants.sandbox.yaml

# Snapshot storage for rollbacks
SNAPSHOT_DIR=./sandbox-data/snapshots

# ===========================================
# Web Dashboard Configuration
# ===========================================
# NextAuth.js configuration for sandbox
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-secure-secret-here

# ===========================================
# Azure AD Authentication (Sandbox)
# ===========================================
# Same as Partner credentials for sandbox
AZURE_AD_CLIENT_ID=your-sandbox-app-registration-id-here
AZURE_AD_CLIENT_SECRET=your-sandbox-client-secret-here
AZURE_AD_TENANT_ID=your-sandbox-tenant-id-here

# ===========================================
# Azure Services (Optional)
# ===========================================
# Azure Key Vault for secure credential storage
# AZURE_KEY_VAULT_URL=https://agentsync-sandbox-kv.vault.azure.net

# ===========================================
# Logging
# ===========================================
# Use debug level for sandbox to help troubleshooting
LOG_LEVEL=debug
NODE_ENV=test

# ===========================================
# Worker Configuration
# ===========================================
# Lower concurrency for sandbox to reduce load
WORKER_CONCURRENCY=2

# Rate limiting (lower for sandbox)
RATE_LIMIT_MAX=5
RATE_LIMIT_DURATION=60000

# ===========================================
# Feature Flags (Sandbox Specific)
# ===========================================
# Skip GDAP validation until real GDAP relationships configured
SKIP_GDAP_VALIDATION=true

# Disable telemetry for testing
DISABLE_TELEMETRY=true

# Disable PostHog analytics in sandbox
# NEXT_PUBLIC_POSTHOG_KEY=

# ===========================================
# Test Configuration
# ===========================================
# For integration/E2E tests
MOCK_DATAVERSE=false  # Set to true for integration tests, false for E2E

# ===========================================
# Setup Instructions
# ===========================================
# 1. Sign up for Microsoft 365 Developer Program: https://developer.microsoft.com/microsoft-365/dev-program
# 2. Create a sandbox Azure AD tenant (e.g., agentsync-sandbox.onmicrosoft.com)
# 3. Register an app in Azure AD with required API permissions
# 4. Create Power Platform environments for testing
# 5. Copy this file to .env.sandbox and fill in your actual values
# 6. Generate NEXTAUTH_SECRET: openssl rand -base64 32
# 7. See docs/SANDBOX_SETUP.md for detailed instructions
