# Pax8 CTA CLI sandbox environment configuration
# Copy to .env.sandbox for sandbox testing only

DEMO_MODE=false
ENVIRONMENT=sandbox
SANDBOX_MODE=true

# Partner app credentials (sandbox tenant)
PARTNER_TENANT_ID=your-sandbox-tenant-id-here
PARTNER_CLIENT_ID=your-sandbox-app-registration-id-here
PARTNER_CLIENT_SECRET=your-sandbox-client-secret-here

# Source environment used for exports
SOURCE_TENANT_ID=your-sandbox-tenant-id-here
SOURCE_ENVIRONMENT_URL=https://agentsync-dev-source.crm.dynamics.com

# CLI config paths
CONFIG_PATH=./config/tenants.sandbox.yaml
SOLUTIONS_DIR=./sandbox-data/solutions
SNAPSHOT_DIR=./sandbox-data/snapshots

# Diagnostics
LOG_LEVEL=debug
NODE_ENV=test

# Optional test toggles
SKIP_GDAP_VALIDATION=true
DISABLE_TELEMETRY=true
